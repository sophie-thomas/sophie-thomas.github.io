                        a(href="https://twitter.com/home?status=http%3A//sophiethomas.co.uk/articles/2015-01-10-new-year-resolutions-2015.html%20via%20%40SophieThomas97" target="_blank"): img(src="../assets/images/icons/twitter.png" alt="Share on Twitter")
            
